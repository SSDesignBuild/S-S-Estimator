html, body, #root {
  margin: 0;
  padding: 0;
  background: #111111;
  min-height: 100%;
  height: 100%;
}

body {
  overscroll-behavior: none;
  overflow-x: hidden;
}
* {
  -webkit-tap-highlight-color: transparent;
}

html {
  background: #111111;
}
#root {
  min-height: 100vh;
  background: #111111;
}

html, body {
  background: #111111;
}
body {
  position: relative;
}
